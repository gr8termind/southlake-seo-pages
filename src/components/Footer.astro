---
import { BUSINESS } from '../config';
const year = new Date().getFullYear();

const services = [
  { name: 'Brake Repair in Jonesboro', href: '/brake-repair-jonesboro-ga' },
  { name: 'Oil Change in Jonesboro', href: '/oil-change-jonesboro-ga' },
  { name: 'Check Engine Light Diagnostics', href: '/check-engine-light-jonesboro-ga' },
  { name: 'Auto AC Repair', href: '/auto-ac-repair-jonesboro-ga' },
  { name: 'Transmission Repair', href: '/transmission-repair-jonesboro-ga' }
];

// All company + conversion pages live on this subdomain.
const company = [
  { name: 'About', href: '/about' },
  { name: 'Reviews', href: '/reviews' },
  { name: 'Specials', href: '/specials' },
  { name: 'Coupons', href: '/coupons' },
  { name: 'Financing', href: '/financing' },
  { name: 'FAQ', href: '/faq' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contact', href: '/contact' },
  { name: 'Schedule Service', href: '/schedule-service' }
];

// SEO/utility hubs.
const resources = [
  { name: 'Car Diagnostic Tool', href: '/car-diagnostic' },
  { name: 'Vehicle Symptoms', href: '/symptoms' },
  { name: 'Makes We Service', href: '/makes' },
  { name: 'Maintenance Packages', href: '/maintenance-packages' }
];
---
<footer class="bg-charcoal-950 text-mist">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10">
      <div class="sm:col-span-2 lg:col-span-1">
        <img src={BUSINESS.logo} alt={`${BUSINESS.name} — auto repair in Jonesboro & Morrow, GA`} title={BUSINESS.name} width="150" height="79" decoding="async" class="h-12 w-auto mb-4" loading="lazy" />
        <p class="text-sm leading-relaxed text-smoke">
          {BUSINESS.name} is a full-service auto repair shop serving Jonesboro, Morrow,
          Forest Park, and all of Clayton County, GA. Honest diagnostics, quality parts,
          and repairs done right the first time.
        </p>
        <a
          href={BUSINESS.scheduleUrl}
          class="mt-5 inline-block rounded-md bg-accent-500 px-5 py-2.5 text-sm font-bold text-charcoal-950 hover:bg-accent-400 transition-colors"
        >
          Schedule Service
        </a>
      </div>

      <nav aria-label="Footer services">
        <h2 class="text-sm font-bold uppercase tracking-widest text-accent-500 mb-4">Services</h2>
        <ul class="space-y-2.5 text-sm">
          {services.map((s) => (
            <li><a href={s.href} class="hover:text-accent-400 transition-colors">{s.name}</a></li>
          ))}
          <li><a href="/services" class="font-semibold text-accent-400 hover:text-accent-300 transition-colors">All Services &rarr;</a></li>
        </ul>
      </nav>

      <nav aria-label="Footer service areas">
        <h2 class="text-sm font-bold uppercase tracking-widest text-accent-500 mb-4">Areas We Serve</h2>
        <p class="text-xs font-bold uppercase tracking-wider text-smoke mb-2">Clayton County</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/jonesboro-auto-repair" class="hover:text-accent-400 transition-colors">Jonesboro</a></li>
          <li><a href="/morrow-auto-repair" class="hover:text-accent-400 transition-colors">Morrow</a></li>
          <li><a href="/forest-park-auto-repair" class="hover:text-accent-400 transition-colors">Forest Park</a></li>
          <li><a href="/riverdale-auto-repair" class="hover:text-accent-400 transition-colors">Riverdale</a></li>
          <li><a href="/lake-city-auto-repair" class="hover:text-accent-400 transition-colors">Lake City</a></li>
          <li><a href="/rex-auto-repair" class="hover:text-accent-400 transition-colors">Rex</a></li>
          <li><a href="/lovejoy-auto-repair" class="hover:text-accent-400 transition-colors">Lovejoy</a></li>
          <li><a href="/clayton-county-auto-repair" class="hover:text-accent-400 transition-colors">Clayton County</a></li>
        </ul>
        <p class="text-xs font-bold uppercase tracking-wider text-smoke mt-4 mb-2">Henry &amp; Fayette</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/stockbridge-auto-repair" class="hover:text-accent-400 transition-colors">Stockbridge</a></li>
          <li><a href="/mcdonough-auto-repair" class="hover:text-accent-400 transition-colors">McDonough</a></li>
          <li><a href="/hampton-auto-repair" class="hover:text-accent-400 transition-colors">Hampton</a></li>
          <li><a href="/fayetteville-auto-repair" class="hover:text-accent-400 transition-colors">Fayetteville</a></li>
          <li><a href="/henry-county-auto-repair" class="hover:text-accent-400 transition-colors">Henry County</a></li>
        </ul>
      </nav>

      <nav aria-label="Footer company">
        <h2 class="text-sm font-bold uppercase tracking-widest text-accent-500 mb-4">Company</h2>
        <ul class="space-y-2.5 text-sm">
          {company.map((c) => (
            <li><a href={c.href} class="hover:text-accent-400 transition-colors">{c.name}</a></li>
          ))}
        </ul>
        <h2 class="text-sm font-bold uppercase tracking-widest text-accent-500 mt-6 mb-4">Resources</h2>
        <ul class="space-y-2.5 text-sm">
          {resources.map((r) => (
            <li><a href={r.href} class="hover:text-accent-400 transition-colors">{r.name}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <h2 class="text-sm font-bold uppercase tracking-widest text-accent-500 mb-4">Visit the Shop</h2>
        <address class="not-italic text-sm space-y-3">
          <p>
            {BUSINESS.address.street}<br />
            {BUSINESS.address.city}, {BUSINESS.address.state} {BUSINESS.address.zip}
          </p>
          <p>
            <a href={BUSINESS.phoneHref} class="font-bold text-paper hover:text-accent-400 transition-colors">{BUSINESS.phone}</a>
          </p>
          <p class="text-smoke">{BUSINESS.hoursText}</p>
        </address>
      </div>
    </div>
  </div>

  <div class="border-t border-charcoal-700">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-smoke">
      <p>&copy; {year} {BUSINESS.name}. All rights reserved.</p>
      <p>Trusted auto repair in Jonesboro, Morrow &amp; Forest Park, GA</p>
    </div>
  </div>
</footer>
