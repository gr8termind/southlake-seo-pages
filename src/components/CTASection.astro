---
import { BUSINESS } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ready to Get Back on the Road?',
  description = `Schedule your service online or call our Jonesboro-area shop today. We'll diagnose the problem, explain your options, and get it fixed right the first time.`
} = Astro.props;
---
<section class="bg-accent-500">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 md:py-16">
    <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-8">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-950">{title}</h2>
        <p class="mt-3 text-charcoal-900/80 text-lg leading-relaxed">{description}</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 shrink-0 w-full sm:w-auto">
        <a
          href={BUSINESS.ctaUrl}
          class="rounded-md bg-charcoal-950 px-8 py-4 text-center text-base font-bold text-paper hover:bg-charcoal-800 transition-colors"
        >
          Schedule Service
        </a>
        <a
          href={BUSINESS.phoneHref}
          class="rounded-md border-2 border-charcoal-950 px-8 py-4 text-center text-base font-bold text-charcoal-950 hover:bg-charcoal-950 hover:text-paper transition-colors"
        >
          Call {BUSINESS.phone}
        </a>
      </div>
    </div>
  </div>
</section>
