---
/**
 * Related links + conversion CTA block. Used at the bottom of every service
 * and location page for consistent internal linking (Phase 3) and conversion
 * signals (Phase 6). Descriptive anchor text, no over-optimization — city
 * context personalizes the copy without keyword stuffing.
 *
 * Props:
 *  - services: excluded slugs (e.g. current page) so we don't self-link.
 *  - cities:   optional list of {name, href} for the "Nearby Areas" column.
 *  - cityContext: e.g. "Morrow" — flavors the anchor text when set.
 */
import { BUSINESS } from '../config';

interface Props {
  excludeService?: string;
  cities?: { name: string; href: string }[];
  cityContext?: string;
}

const { excludeService, cities = [], cityContext } = Astro.props as Props;

const allServices = [
  { slug: 'brake-repair-jonesboro-ga', label: 'Brake repair &amp; inspection' },
  { slug: 'oil-change-jonesboro-ga', label: 'Oil changes &amp; maintenance' },
  { slug: 'check-engine-light-jonesboro-ga', label: 'Check engine light diagnostics' },
  { slug: 'auto-ac-repair-jonesboro-ga', label: 'Auto A/C repair' },
  { slug: 'transmission-repair-jonesboro-ga', label: 'Transmission service &amp; repair' }
];
const related = allServices.filter((s) => s.slug !== excludeService);

const ctx = cityContext ? ` in ${cityContext}` : '';
---
<section class="bg-charcoal-950 text-paper py-14 md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="label text-accent-400">Keep Exploring</p>
    <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight">Everything You Need in One Shop</h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="label text-accent-500">Related Services</h3>
        <ul class="mt-4 space-y-2.5 text-sm">
          {related.map((s) => (
            <li><a href={`/${s.slug}`} class="text-mist hover:text-accent-400 transition-colors" set:html={s.label}></a></li>
          ))}
          <li><a href="/services" class="font-semibold text-accent-400 hover:text-accent-300">See all auto repair services &rarr;</a></li>
        </ul>
      </div>

      {cities.length > 0 && (
        <div>
          <h3 class="label text-accent-500">Nearby Areas We Serve</h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            {cities.map((c) => (
              <li><a href={c.href} class="text-mist hover:text-accent-400 transition-colors">Auto repair in {c.name}</a></li>
            ))}
          </ul>
        </div>
      )}

      <div>
        <h3 class="label text-accent-500">Helpful Resources</h3>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href="/reviews" class="text-mist hover:text-accent-400 transition-colors">Read customer reviews</a></li>
          <li><a href="/financing" class="text-mist hover:text-accent-400 transition-colors">Apply for financing</a></li>
          <li><a href="/specials" class="text-mist hover:text-accent-400 transition-colors">Current service specials</a></li>
          <li><a href="/faq" class="text-mist hover:text-accent-400 transition-colors">Auto repair FAQ</a></li>
          <li><a href="/car-diagnostic" class="text-mist hover:text-accent-400 transition-colors">Interactive car diagnostic</a></li>
          <li><a href="/about" class="text-mist hover:text-accent-400 transition-colors">About our shop</a></li>
        </ul>
      </div>

      <div>
        <h3 class="label text-accent-500">Ready to Book?</h3>
        <p class="mt-4 text-sm text-mist leading-relaxed">Same-day service on most repairs. Free estimates. Honest diagnostics.</p>
        <div class="mt-5 space-y-3">
          <a href={BUSINESS.scheduleUrl} class="block rounded-md bg-accent-500 px-5 py-3 text-center text-sm font-bold text-charcoal-950 hover:bg-accent-400 transition-colors">Schedule Service{ctx}</a>
          <a href={BUSINESS.ctaUrl} class="block rounded-md border border-accent-500/50 px-5 py-3 text-center text-sm font-bold text-paper hover:bg-accent-500/10 transition-colors">Request a Quote</a>
          <a href={BUSINESS.phoneHref} class="block text-center text-sm font-semibold text-accent-400 hover:text-accent-300">Or call {BUSINESS.phone}</a>
        </div>
      </div>
    </div>
  </div>
</section>
