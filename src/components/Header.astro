---
import { BUSINESS } from '../config';

// Flat top-level nav matching the brand header. Everything else (individual
// service pages, city pages, FAQ) lives in the footer.
const nav = [
  { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
  { name: 'Services', href: '/services' },
  { name: 'About', href: '/about' },
  { name: 'Reviews', href: '/reviews' },
  { name: 'Specials', href: '/specials' },
  { name: 'Financing', href: '/financing' },
  { name: 'Contact', href: '/contact' }
];
---
<header class="sticky top-0 z-40 bg-charcoal-950 border-b border-charcoal-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 md:h-20 items-center justify-between gap-4">
      <a href={BUSINESS.mainSiteUrl + '/'} class="flex items-center gap-3 shrink-0" aria-label={`${BUSINESS.name} home`}>
        <img src={BUSINESS.logo} alt={`${BUSINESS.name} logo`} width="150" height="79" class="h-10 md:h-12 w-auto" loading="eager" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-7 text-sm font-semibold text-paper" aria-label="Primary">
        {nav.map((item) => (
          <a href={item.href} class="hover:text-accent-400 transition-colors">{item.name}</a>
        ))}
      </nav>

      <!-- Desktop actions -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href={BUSINESS.phoneHref}
          class="inline-flex items-center gap-2 rounded-md border-2 border-accent-500 px-5 py-2.5 text-sm font-bold text-paper hover:bg-accent-500/10 transition-colors"
        >
          <svg class="h-4 w-4 text-accent-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.02l-2.2 2.21z"/></svg>
          Call Now
        </a>
        <a
          href={BUSINESS.scheduleUrl}
          class="inline-flex items-center gap-2 rounded-md bg-accent-500 px-5 py-2.5 text-sm font-bold text-charcoal-950 hover:bg-accent-400 transition-colors"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          Schedule Service
        </a>
      </div>

      <!-- Mobile: call + hamburger (CSS-only) -->
      <div class="flex lg:hidden items-center gap-3">
        <a href={BUSINESS.phoneHref} aria-label={`Call ${BUSINESS.phone}`} class="rounded-md border-2 border-accent-500 p-2 text-accent-500">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.02l-2.2 2.21z"/></svg>
        </a>
        <input type="checkbox" id="nav-toggle" class="peer sr-only" />
        <label for="nav-toggle" class="cursor-pointer p-2 text-paper" aria-label="Open menu">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </label>
        <nav class="hidden peer-checked:block absolute left-0 right-0 top-full bg-charcoal-900 border-b border-charcoal-700 shadow-2xl" aria-label="Mobile">
          <div class="px-4 py-4 space-y-1 text-paper font-semibold">
            {nav.map((item) => (
              <a href={item.href} class="block rounded-md px-3 py-2.5 hover:bg-charcoal-800">{item.name}</a>
            ))}
            <div class="grid grid-cols-2 gap-3 pt-3">
              <a href={BUSINESS.phoneHref} class="inline-flex items-center justify-center gap-2 rounded-md border-2 border-accent-500 px-4 py-3 text-center font-bold text-paper">
                <svg class="h-4 w-4 text-accent-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.02l-2.2 2.21z"/></svg>
                Call Now
              </a>
              <a href={BUSINESS.scheduleUrl} class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-4 py-3 text-center font-bold text-charcoal-950">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                Schedule
              </a>
            </div>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>
