---
import { BUSINESS } from '../config';

const services = [
  { name: 'Brake Repair', href: '/brake-repair-jonesboro-ga' },
  { name: 'Oil Change', href: '/oil-change-jonesboro-ga' },
  { name: 'Check Engine Light', href: '/check-engine-light-jonesboro-ga' },
  { name: 'Auto AC Repair', href: '/auto-ac-repair-jonesboro-ga' },
  { name: 'Transmission Repair', href: '/transmission-repair-jonesboro-ga' }
];

const areas = [
  { name: 'Morrow', href: '/morrow-auto-repair' },
  { name: 'Forest Park', href: '/forest-park-auto-repair' }
];

// Company + conversion pages — all on this subdomain.
const more = [
  { name: 'About', href: '/about' },
  { name: 'Reviews', href: '/reviews' },
  { name: 'Specials', href: '/specials' },
  { name: 'Financing', href: '/financing' },
  { name: 'FAQ', href: '/faq' },
  { name: 'Contact', href: '/contact' }
];
---
<header class="sticky top-0 z-40 bg-charcoal-900/95 backdrop-blur border-b border-charcoal-700">
  <!-- Top utility bar -->
  <div class="hidden md:block bg-charcoal-950 text-xs text-smoke">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between py-1.5">
      <p>{BUSINESS.address.street}, {BUSINESS.address.city}, {BUSINESS.address.state} {BUSINESS.address.zip}</p>
      <p>{BUSINESS.hoursText} <span class="mx-2 text-charcoal-600">|</span> Serving Jonesboro, Morrow &amp; Forest Park</p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 md:h-20 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 shrink-0" aria-label={`${BUSINESS.name} home`}>
        <img src={BUSINESS.logo} alt={`${BUSINESS.name} logo`} width="150" height="79" class="h-10 md:h-12 w-auto" loading="eager" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-7 text-sm font-semibold text-paper" aria-label="Primary">
        <a href="/" class="hover:text-accent-400 transition-colors">Home</a>
        <div class="relative group">
          <span class="inline-flex items-center gap-1 py-6 cursor-default">
            Services
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
          </span>
          <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 transition-all absolute left-0 top-full w-64 rounded-lg bg-charcoal-800 border border-charcoal-700 shadow-xl py-2">
            {services.map((s) => (
              <a href={s.href} class="block px-4 py-2.5 text-mist hover:text-accent-400 hover:bg-charcoal-700 transition-colors">{s.name}</a>
            ))}
          </div>
        </div>
        <div class="relative group">
          <span class="inline-flex items-center gap-1 py-6 cursor-default">
            Areas We Serve
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
          </span>
          <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 transition-all absolute left-0 top-full w-56 rounded-lg bg-charcoal-800 border border-charcoal-700 shadow-xl py-2">
            {areas.map((a) => (
              <a href={a.href} class="block px-4 py-2.5 text-mist hover:text-accent-400 hover:bg-charcoal-700 transition-colors">{a.name} Auto Repair</a>
            ))}
          </div>
        </div>
        <div class="relative group">
          <span class="inline-flex items-center gap-1 py-6 cursor-default">
            More
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
          </span>
          <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 transition-all absolute left-0 top-full w-52 rounded-lg bg-charcoal-800 border border-charcoal-700 shadow-xl py-2">
            {more.map((m) => (
              <a href={m.href} class="block px-4 py-2.5 text-mist hover:text-accent-400 hover:bg-charcoal-700 transition-colors">{m.name}</a>
            ))}
          </div>
        </div>
      </nav>

      <div class="hidden lg:flex items-center gap-4">
        <a href={BUSINESS.phoneHref} class="flex items-center gap-2 text-paper font-bold hover:text-accent-400 transition-colors">
          <svg class="h-5 w-5 text-accent-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.02l-2.2 2.21z"/></svg>
          {BUSINESS.phone}
        </a>
        <a
          href={BUSINESS.scheduleUrl}
          class="rounded-md bg-accent-500 px-5 py-2.5 text-sm font-bold text-charcoal-950 hover:bg-accent-400 transition-colors shadow-[0_0_0_1px_rgba(0,0,0,.15)]"
        >
          Schedule Service
        </a>
      </div>

      <!-- Mobile: phone + hamburger (CSS-only) -->
      <div class="flex lg:hidden items-center gap-3">
        <a href={BUSINESS.phoneHref} aria-label={`Call ${BUSINESS.phone}`} class="rounded-md bg-accent-500 p-2.5 text-charcoal-950">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.02l-2.2 2.21z"/></svg>
        </a>
        <input type="checkbox" id="nav-toggle" class="peer sr-only" />
        <label for="nav-toggle" class="cursor-pointer p-2 text-paper" aria-label="Open menu">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </label>
        <nav class="hidden peer-checked:block absolute left-0 right-0 top-full bg-charcoal-900 border-b border-charcoal-700 shadow-2xl" aria-label="Mobile">
          <div class="px-4 py-4 space-y-1 text-paper font-semibold">
            <a href="/" class="block rounded-md px-3 py-2.5 hover:bg-charcoal-800">Home</a>
            <p class="px-3 pt-3 pb-1 text-xs uppercase tracking-widest text-accent-500">Services</p>
            {services.map((s) => (
              <a href={s.href} class="block rounded-md px-3 py-2.5 text-mist hover:bg-charcoal-800">{s.name}</a>
            ))}
            <p class="px-3 pt-3 pb-1 text-xs uppercase tracking-widest text-accent-500">Areas We Serve</p>
            {areas.map((a) => (
              <a href={a.href} class="block rounded-md px-3 py-2.5 text-mist hover:bg-charcoal-800">{a.name} Auto Repair</a>
            ))}
            <p class="px-3 pt-3 pb-1 text-xs uppercase tracking-widest text-accent-500">More</p>
            {more.map((m) => (
              <a href={m.href} class="block rounded-md px-3 py-2.5 text-mist hover:bg-charcoal-800">{m.name}</a>
            ))}
            <a href={BUSINESS.scheduleUrl} class="mt-3 block rounded-md bg-accent-500 px-4 py-3 text-center font-bold text-charcoal-950">Schedule Service</a>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>
