---
import { SITE_URL, BUSINESS } from '../config';

interface Props {
  name: string;
  description: string;
  path: string;
  serviceType: string;
}

const { name, description, path, serviceType } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  description,
  serviceType,
  url: `${SITE_URL}${path}`,
  provider: { '@id': `${SITE_URL}/#autorepair` },
  areaServed: BUSINESS.serviceAreas.map((n) => ({ '@type': 'City', name: `${n}, GA` }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
