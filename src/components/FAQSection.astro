---
import type { FAQ } from '../config';

interface Props {
  title?: string;
  faqs: FAQ[];
}

const { title = 'Frequently Asked Questions', faqs } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a }
  }))
};
---
<section class="bg-paper py-16 md:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-bold uppercase tracking-widest text-accent-600">Good to Know</p>
    <h2 class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">{title}</h2>
    <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>

    <div class="mt-10 space-y-4">
      {faqs.map((f) => (
        <details class="group rounded-lg border border-mist/70 bg-white shadow-sm open:shadow-md transition-shadow">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left font-bold text-charcoal-900 list-none">
            {f.q}
            <svg class="faq-chevron h-5 w-5 shrink-0 text-accent-600 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
          </summary>
          <div class="px-5 pb-5 text-charcoal-700 leading-relaxed">
            <p>{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
