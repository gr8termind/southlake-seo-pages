---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import CTASection from '../components/CTASection.astro';
import { BUSINESS } from '../config';

const path = '/car-diagnostic';
const title = "Car Diagnostic Tool | What's Wrong With My Car? | Southlake Auto Care";
const description =
  "Not sure what's wrong with your car? Tap the part that's giving you trouble and get a fast quote from Southlake Auto Care in Jonesboro & Morrow, GA. Call (770) 961-8500.";

// Each hotspot: position is a % of the diagram box (left/top). Front of car = left.
const hotspots = [
  { id: 'engine', label: 'Check Engine & Diagnostics', x: 22, y: 50, signs: 'Check engine light, rough idle, stalling, poor mileage.', desc: 'That glowing dash light could mean a dozen things. We run professional diagnostics to find the real cause — not just clear the code.', href: '/check-engine-light-jonesboro-ga', service: 'Check engine diagnostics' },
  { id: 'battery', label: 'Battery & Electrical', x: 30, y: 34, signs: 'Slow crank, dim or flickering lights, no-start.', desc: 'Slow to start or a dead battery? We test the battery, alternator, and charging system to find the culprit.', href: '/schedule-service', service: 'Electrical service' },
  { id: 'oil', label: 'Oil & Fluids', x: 33, y: 70, signs: 'Oil light, overdue service, low or dark oil.', desc: 'Fresh oil is the cheapest insurance your engine can buy. We change the oil and top every fluid, with a full inspection.', href: '/oil-change-jonesboro-ga', service: 'Oil change' },
  { id: 'ac', label: 'A/C & Cooling', x: 45, y: 40, signs: 'Weak airflow, warm air, overheating.', desc: 'Warm air in a Georgia summer? We find leaks and repair the A/C and cooling system so you stay cold.', href: '/auto-ac-repair-jonesboro-ga', service: 'A/C repair' },
  { id: 'transmission', label: 'Transmission', x: 55, y: 66, signs: 'Slipping, hard or delayed shifts, leaks.', desc: 'Slipping or shifting hard? From fluid service to full repair, we give you honest options — not a scare tactic.', href: '/transmission-repair-jonesboro-ga', service: 'Transmission service' },
  { id: 'brakes', label: 'Brakes', x: 27, y: 82, signs: 'Squeal, grind, vibration, soft pedal.', desc: 'Squealing, grinding, or a soft pedal? We inspect and repair pads, rotors, and calipers so you stop safely.', href: '/brake-repair-jonesboro-ga', service: 'Brake repair' },
  { id: 'tires', label: 'Tires & Suspension', x: 73, y: 82, signs: 'Pulling, bouncing, uneven tire wear.', desc: 'Rough ride, pulling, or uneven tire wear? We check suspension, alignment, and tires to smooth things out.', href: '/schedule-service', service: 'Suspension check' }
];
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <Breadcrumbs
    items={[
      { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
      { name: 'Car Diagnostic', href: path }
    ]}
  />

  <section class="bg-charcoal-900 text-paper py-14 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="label text-accent-400">Interactive Diagnosis</p>
      <h1 class="mt-3 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05]">
        Point to the problem.<br class="hidden sm:block" /> We'll take it from here.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-mist leading-relaxed">
        Not sure how to describe what's wrong? Tap the part of the car that's giving you trouble.
        We'll tell you what it usually means and get you a fast quote.
      </p>

      <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <!-- Interactive diagram -->
        <div class="lg:col-span-2">
          <div id="diagram" class="relative w-full rounded-2xl border border-charcoal-700 bg-charcoal-950 overflow-hidden" style="aspect-ratio: 1000 / 480;">
            <svg viewBox="0 0 1000 480" class="absolute inset-0 h-full w-full" role="img" aria-label="Side view of a car — tap a highlighted part">
              <!-- tread texture -->
              <defs>
                <pattern id="tread" width="26" height="26" patternTransform="rotate(135)" patternUnits="userSpaceOnUse">
                  <line x1="0" y1="0" x2="0" y2="26" stroke="#ffffff" stroke-opacity="0.05" stroke-width="2" />
                </pattern>
              </defs>
              <rect x="0" y="0" width="1000" height="480" fill="url(#tread)" />
              <!-- ground -->
              <line x1="60" y1="400" x2="940" y2="400" stroke="#2e2e2e" stroke-width="3" />
              <!-- car body -->
              <path d="M150 330 Q150 300 185 296 L300 292 Q330 250 400 244 L470 244 L540 196 L690 194 Q735 196 770 250 L850 258 Q885 262 892 300 L892 330 Z"
                    fill="#1f1f1f" stroke="#2e2e2e" stroke-width="2" />
              <!-- cabin glass -->
              <path d="M486 246 L548 205 L636 204 L636 246 Z" fill="#111111" stroke="#84c023" stroke-opacity="0.35" stroke-width="2" />
              <path d="M648 205 L678 246 L648 246 Z" fill="#111111" stroke="#84c023" stroke-opacity="0.35" stroke-width="2" />
              <!-- lime beltline accent -->
              <path d="M185 300 L860 300" stroke="#84c023" stroke-width="3" stroke-opacity="0.55" />
              <!-- wheels -->
              <g>
                <circle cx="330" cy="360" r="62" fill="#0d0d0d" stroke="#2e2e2e" stroke-width="3" />
                <circle cx="330" cy="360" r="26" fill="none" stroke="#84c023" stroke-opacity="0.5" stroke-width="4" />
                <circle cx="720" cy="360" r="62" fill="#0d0d0d" stroke="#2e2e2e" stroke-width="3" />
                <circle cx="720" cy="360" r="26" fill="none" stroke="#84c023" stroke-opacity="0.5" stroke-width="4" />
              </g>
            </svg>

            {hotspots.map((h) => (
              <button
                type="button"
                class="hotspot"
                style={`left:${h.x}%;top:${h.y}%`}
                data-id={h.id}
                data-label={h.label}
                data-desc={h.desc}
                data-signs={h.signs}
                data-href={h.href}
                data-service={h.service}
                aria-pressed="false"
                aria-label={h.label}
              >
                <span class="hotspot-dot" aria-hidden="true"></span>
              </button>
            ))}
          </div>
          <p class="mt-3 text-sm text-smoke">Tap a highlighted point on the car. Not sure? <a href="#quote" class="font-semibold text-accent-400 hover:text-accent-300 underline underline-offset-2">Just describe it below.</a></p>
        </div>

        <!-- Info panel -->
        <aside id="panel" class="rounded-2xl border border-charcoal-700 bg-charcoal-950 p-6 md:p-7">
          <div id="panel-empty">
            <p class="label text-accent-400">Select a part</p>
            <p class="mt-3 text-lg text-mist leading-relaxed">Tap the area that's acting up and we'll show you what it usually means — then get you a quote.</p>
            <ul class="mt-5 space-y-2 text-sm text-smoke">
              <li>· Honest diagnosis, no scare tactics</li>
              <li>· Upfront pricing before any work</li>
              <li>· Serving Jonesboro, Morrow &amp; Clayton County</li>
            </ul>
          </div>
          <div id="panel-content" class="hidden">
            <p class="label text-accent-400">Likely Area</p>
            <h2 id="p-label" class="mt-3 text-2xl font-extrabold tracking-tight text-paper"></h2>
            <p id="p-desc" class="mt-3 text-mist leading-relaxed"></p>
            <div class="mt-4 rounded-lg border border-charcoal-700 bg-charcoal-900 p-4">
              <p class="text-xs font-bold uppercase tracking-wider text-smoke">Common signs</p>
              <p id="p-signs" class="mt-1 text-sm text-mist"></p>
            </div>
            <button type="button" id="p-quote" class="mt-6 w-full rounded-md bg-accent-500 px-6 py-4 text-base font-bold text-charcoal-950 hover:bg-accent-400 transition-colors">
              Get a Quote for This
            </button>
            <a id="p-learn" href="#" class="mt-3 block text-center text-sm font-semibold text-accent-400 hover:text-accent-300">Learn about this service &rarr;</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section id="quote" class="bg-white py-16 md:py-20 scroll-mt-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="label text-accent-600">Request a Quote</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">Tell Us What Your Car Needs</h2>
      <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <p id="concern-note" class="mt-6 hidden rounded-lg border-l-4 border-accent-500 bg-paper px-4 py-3 text-charcoal-800 font-semibold"></p>
      <p class="mt-6 text-lg text-charcoal-700 leading-relaxed">Add your vehicle details below and we'll send a quote and get you scheduled.</p>
      <div class="mt-8">
        <QuoteForm bare={true} height={780} />
      </div>
    </div>
  </section>

  <CTASection
    title="Prefer to Talk It Through?"
    description={`Call ${BUSINESS.phone} and describe what's happening — we'll tell you what to check and what it'll take to fix.`}
  />

  <style>
    .hotspot {
      position: absolute;
      transform: translate(-50%, -50%);
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 9999px;
      cursor: pointer;
      background: transparent;
      border: 0;
    }
    .hotspot:focus-visible { outline: 2px solid #94cd3f; outline-offset: 3px; }
    .hotspot-dot {
      width: 16px; height: 16px; border-radius: 9999px;
      background: #84c023;
      box-shadow: 0 0 0 4px rgba(132,192,35,0.25);
      transition: transform .15s ease;
    }
    .hotspot::after {
      content: ""; position: absolute; inset: 0; border-radius: 9999px;
      border: 2px solid #84c023; opacity: .7;
      animation: hs-pulse 2s ease-out infinite;
    }
    .hotspot:hover .hotspot-dot { transform: scale(1.25); }
    .hotspot[aria-pressed="true"] .hotspot-dot {
      background: #ffffff; transform: scale(1.3);
      box-shadow: 0 0 0 5px rgba(132,192,35,0.5);
    }
    @keyframes hs-pulse {
      0% { transform: scale(1); opacity: .7; }
      70% { transform: scale(2.1); opacity: 0; }
      100% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hotspot::after { animation: none; opacity: 0; }
    }
  </style>

  <script is:inline>
    (function () {
      var buttons = Array.prototype.slice.call(document.querySelectorAll('.hotspot'));
      var empty = document.getElementById('panel-empty');
      var content = document.getElementById('panel-content');
      var pLabel = document.getElementById('p-label');
      var pDesc = document.getElementById('p-desc');
      var pSigns = document.getElementById('p-signs');
      var pLearn = document.getElementById('p-learn');
      var pQuote = document.getElementById('p-quote');
      var concernNote = document.getElementById('concern-note');
      var current = null;

      function select(btn) {
        buttons.forEach(function (b) { b.setAttribute('aria-pressed', String(b === btn)); });
        current = {
          label: btn.getAttribute('data-label'),
          desc: btn.getAttribute('data-desc'),
          signs: btn.getAttribute('data-signs'),
          href: btn.getAttribute('data-href'),
          service: btn.getAttribute('data-service')
        };
        pLabel.textContent = current.label;
        pDesc.textContent = current.desc;
        pSigns.textContent = current.signs;
        pLearn.setAttribute('href', current.href);
        empty.classList.add('hidden');
        content.classList.remove('hidden');
      }

      buttons.forEach(function (b) {
        b.addEventListener('click', function () { select(b); });
      });

      if (pQuote) {
        pQuote.addEventListener('click', function () {
          if (current && concernNote) {
            concernNote.textContent = "You're asking about: " + current.label + ". Mention this in your request.";
            concernNote.classList.remove('hidden');
          }
          var q = document.getElementById('quote');
          if (q) q.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    })();
  </script>
</BaseLayout>
