---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import CTASection from '../components/CTASection.astro';
import { BUSINESS } from '../config';

const path = '/car-diagnostic';
const title = "Car Diagnostic Tool | What's Wrong With My Car? | Southlake Auto Care";
const description =
  "Not sure what's wrong with your car? Pick the system that's giving you trouble and get a fast quote from Southlake Auto Care in Jonesboro & Morrow, GA. Call (770) 961-8500.";

// Each category maps to a shop service. Order matters — most common concerns first.
const parts = [
  { id: 'engine',       label: 'Engine & Check Engine Light', signs: 'Check engine light, rough idle, stalling, poor fuel economy.',      desc: "That glowing dash light could mean a dozen things. We run professional diagnostics to find the real cause — not just clear the code.", href: '/check-engine-light-jonesboro-ga', service: 'Check engine diagnostics', iconPath: 'M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12M12 8a4 4 0 100 8 4 4 0 000-8z' },
  { id: 'brakes',       label: 'Brakes',                      signs: 'Squealing, grinding, vibration when braking, soft pedal.',            desc: 'Squealing, grinding, or a soft pedal? We inspect pads, rotors, and calipers, and show you exactly what needs to be fixed.',        href: '/brake-repair-jonesboro-ga',        service: 'Brake repair',              iconPath: 'M12 2a10 10 0 100 20 10 10 0 000-20zm0 4a6 6 0 110 12 6 6 0 010-12zm0 4a2 2 0 100 4 2 2 0 000-4z' },
  { id: 'ac',           label: 'A/C & Heating',               signs: 'Weak airflow, warm air, musty smell, no heat.',                       desc: 'Warm air in a Georgia summer? We find leaks and repair the A/C and cooling system so your cabin stays comfortable year-round.',    href: '/auto-ac-repair-jonesboro-ga',      service: 'A/C repair',                iconPath: 'M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07' },
  { id: 'oil',          label: 'Oil & Fluids',                signs: 'Oil light on, service overdue, low or dark oil, fluid leaks.',        desc: 'Fresh oil is the cheapest insurance your engine can buy. We do it right — correct spec, proper filter, real inspection every time.', href: '/oil-change-jonesboro-ga',          service: 'Oil change',                iconPath: 'M12 2c-4 6-6 9-6 12a6 6 0 0012 0c0-3-2-6-6-12z' },
  { id: 'transmission', label: 'Transmission',                signs: 'Slipping, hard or delayed shifts, whining, fluid leaks.',             desc: 'Slipping or shifting hard? From fluid service to targeted repairs, we give you honest options — not a scare-tactic rebuild quote.', href: '/transmission-repair-jonesboro-ga', service: 'Transmission service',      iconPath: 'M4 8h16M4 12h16M4 16h16M8 4v16M16 4v16' },
  { id: 'battery',      label: 'Battery & Electrical',        signs: 'Slow crank, dim or flickering lights, no-start, dead battery.',       desc: 'Slow to start or dead battery? We test the battery, alternator, and charging system to find the actual culprit.',                    href: '/schedule-service',                  service: 'Battery & electrical check', iconPath: 'M6 7h12v10H6zM9 4h6v3H9zM10 12h4' },
  { id: 'tires',        label: 'Tires, Suspension & Steering',signs: 'Pulling, bouncing, uneven tire wear, steering wheel vibration.',      desc: 'Rough ride, pulling, or uneven tire wear? We check suspension, alignment, and tires to smooth things out.',                        href: '/schedule-service',                  service: 'Suspension & alignment',    iconPath: 'M4 12a8 8 0 1116 0 8 8 0 01-16 0zm4 0a4 4 0 108 0 4 4 0 00-8 0z' },
  { id: 'other',        label: "Not Sure / Something Else",   signs: 'A noise, smell, warning light, or symptom that doesn\u2019t fit above.', desc: "Not sure what it is? Describe what you're noticing and we'll help figure it out — no need to know the exact part.",                  href: '#quote',                             service: 'General diagnostic',        iconPath: 'M12 2a10 10 0 100 20 10 10 0 000-20zM9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01' }
];
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <Breadcrumbs
    items={[
      { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
      { name: 'Car Diagnostic', href: path }
    ]}
  />

  <section class="bg-charcoal-900 text-paper py-14 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="label text-accent-400">Interactive Diagnosis</p>
      <h1 class="mt-3 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05]">
        Pick the system.<br class="hidden sm:block" /> We'll take it from here.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-mist leading-relaxed">
        Not sure how to describe what's wrong? Choose the area that's giving you trouble below.
        We'll tell you what it usually means and get you a fast quote.
      </p>

      <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <!-- Card grid -->
        <div class="lg:col-span-2">
          <div id="parts-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-3" role="radiogroup" aria-label="Select a vehicle system">
            {parts.map((p) => (
              <button
                type="button"
                class="part-btn group flex items-start gap-4 rounded-xl border border-charcoal-700 bg-charcoal-950 p-4 text-left hover:border-accent-500 hover:bg-charcoal-800 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-400 focus-visible:outline-offset-2"
                data-id={p.id}
                data-label={p.label}
                data-desc={p.desc}
                data-signs={p.signs}
                data-href={p.href}
                data-service={p.service}
                role="radio"
                aria-checked="false"
              >
                <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-500/15 text-accent-400 group-hover:bg-accent-500 group-hover:text-charcoal-950 transition-colors">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.iconPath} /></svg>
                </span>
                <span>
                  <span class="block text-base font-bold text-paper">{p.label}</span>
                  <span class="mt-1 block text-sm text-smoke leading-snug">{p.signs}</span>
                </span>
              </button>
            ))}
          </div>
          <p class="mt-4 text-sm text-smoke">Tap a system that matches what you're seeing. Not sure? <a href="#quote" class="font-semibold text-accent-400 hover:text-accent-300 underline underline-offset-2">Just describe it below.</a></p>
        </div>

        <!-- Info panel -->
        <aside id="panel" class="rounded-2xl border border-charcoal-700 bg-charcoal-950 p-6 md:p-7 lg:sticky lg:top-24">
          <div id="panel-empty">
            <p class="label text-accent-400">Select a system</p>
            <p class="mt-3 text-lg text-mist leading-relaxed">Pick the area that's acting up and we'll show you what it usually means — then get you a quote.</p>
            <ul class="mt-5 space-y-2 text-sm text-smoke">
              <li>· Honest diagnosis, no scare tactics</li>
              <li>· Upfront pricing before any work</li>
              <li>· Serving Jonesboro, Morrow &amp; Clayton County</li>
            </ul>
          </div>
          <div id="panel-content" class="hidden">
            <p class="label text-accent-400">Likely Area</p>
            <h2 id="p-label" class="mt-3 text-2xl font-extrabold tracking-tight text-paper"></h2>
            <p id="p-desc" class="mt-3 text-mist leading-relaxed"></p>
            <div class="mt-4 rounded-lg border border-charcoal-700 bg-charcoal-900 p-4">
              <p class="text-xs font-bold uppercase tracking-wider text-smoke">Common signs</p>
              <p id="p-signs" class="mt-1 text-sm text-mist"></p>
            </div>
            <button type="button" id="p-quote" class="mt-6 w-full rounded-md bg-accent-500 px-6 py-4 text-base font-bold text-charcoal-950 hover:bg-accent-400 transition-colors">
              Get a Quote for This
            </button>
            <a id="p-learn" href="#" class="mt-3 block text-center text-sm font-semibold text-accent-400 hover:text-accent-300">Learn about this service &rarr;</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section id="quote" class="bg-white py-16 md:py-20 scroll-mt-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="label text-accent-600">Request a Quote</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">Tell Us What Your Car Needs</h2>
      <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <p id="concern-note" class="mt-6 hidden rounded-lg border-l-4 border-accent-500 bg-paper px-4 py-3 text-charcoal-800 font-semibold"></p>
      <p class="mt-6 text-lg text-charcoal-700 leading-relaxed">Add your vehicle details below and we'll send a quote and get you scheduled.</p>
      <div class="mt-8">
        <QuoteForm bare={true} height={780} />
      </div>
    </div>
  </section>

  <CTASection
    title="Prefer to Talk It Through?"
    description={`Call ${BUSINESS.phone} and describe what's happening — we'll tell you what to check and what it'll take to fix.`}
  />

  <style>
    .part-btn[aria-checked="true"] {
      border-color: #84c023;
      background: rgba(132, 192, 35, 0.08);
    }
    .part-btn[aria-checked="true"] .part-btn-icon,
    .part-btn[aria-checked="true"] span > span {
      color: inherit;
    }
  </style>

  <script is:inline>
    (function () {
      var buttons = Array.prototype.slice.call(document.querySelectorAll('.part-btn'));
      var empty = document.getElementById('panel-empty');
      var content = document.getElementById('panel-content');
      var pLabel = document.getElementById('p-label');
      var pDesc = document.getElementById('p-desc');
      var pSigns = document.getElementById('p-signs');
      var pLearn = document.getElementById('p-learn');
      var pQuote = document.getElementById('p-quote');
      var concernNote = document.getElementById('concern-note');
      var current = null;

      function select(btn) {
        buttons.forEach(function (b) { b.setAttribute('aria-checked', String(b === btn)); });
        current = {
          label: btn.getAttribute('data-label'),
          desc: btn.getAttribute('data-desc'),
          signs: btn.getAttribute('data-signs'),
          href: btn.getAttribute('data-href'),
          service: btn.getAttribute('data-service')
        };
        pLabel.textContent = current.label;
        pDesc.textContent = current.desc;
        pSigns.textContent = current.signs;
        pLearn.setAttribute('href', current.href);
        // For "Other" the learn link points at #quote — hide the redundant CTA row.
        var isOther = current.href === '#quote';
        pLearn.style.display = isOther ? 'none' : '';
        empty.classList.add('hidden');
        content.classList.remove('hidden');
        // On mobile the panel is below the grid — scroll it into view.
        if (window.innerWidth < 1024) {
          content.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      buttons.forEach(function (b) {
        b.addEventListener('click', function () { select(b); });
      });

      if (pQuote) {
        pQuote.addEventListener('click', function () {
          if (current && concernNote) {
            concernNote.textContent = "You're asking about: " + current.label + ". Mention this in your request.";
            concernNote.classList.remove('hidden');
          }
          var q = document.getElementById('quote');
          if (q) q.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    })();
  </script>
</BaseLayout>
