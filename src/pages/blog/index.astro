---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { BUSINESS } from '../../config';
import { POSTS } from '../../data/posts';

const path = '/blog';
const title = 'Auto Repair Blog | Tips from Southlake Auto Care | Jonesboro & Morrow, GA';
const description = 'Straightforward auto repair advice from Southlake Auto Care in Morrow, GA. Maintenance tips, common problems, and honest answers for Clayton County drivers.';
const sorted = [...POSTS].sort((a, b) => (b.publishedISO || '').localeCompare(a.publishedISO || ''));
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <Breadcrumbs items={[
    { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
    { name: 'Blog', href: path }
  ]} />
  <Hero eyebrow="From the Shop" title="Auto Repair Tips &amp; Advice" description="No jargon, no upsells — just useful advice from the shop." />
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {sorted.length === 0 ? (
        <p class="text-lg text-charcoal-700 leading-relaxed">Articles coming soon. In the meantime, browse our <a href="/faq" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2">FAQ</a> or call <a href={BUSINESS.phoneHref} class="font-bold text-accent-700 hover:text-accent-600">{BUSINESS.phone}</a>.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sorted.map((p) => (
            <a href={`/blog/${p.slug}`} class="rounded-xl border border-mist/70 bg-paper p-6 hover:border-accent-500 hover:shadow-sm transition-all">
              <p class="label text-accent-600">{p.category}</p>
              <h2 class="mt-2 text-xl font-bold text-charcoal-900">{p.headline}</h2>
              <p class="mt-2 text-charcoal-700 leading-relaxed">{p.excerpt}</p>
              <p class="mt-3 text-sm text-charcoal-500">{p.readMinutes} min read</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  <RelatedLinks />
  <CTASection title="Have a Specific Question?" description={`Call ${BUSINESS.phone} — we're happy to help.`} />
</BaseLayout>
