---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { SITE_URL, BUSINESS } from '../../config';
import { COUPONS } from '../../data/coupons';

export function getStaticPaths() {
  return COUPONS.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}
const { c } = Astro.props;
const path = `/coupons/${c.slug}`;

const offerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Offer',
  name: c.headline,
  description: c.description,
  url: `${SITE_URL}${path}`,
  seller: { '@id': `${SITE_URL}/#autorepair` },
  ...(c.expires && { validThrough: c.expires })
};
---
<BaseLayout title={c.title} description={c.description} canonicalPath={path}>
  <script type="application/ld+json" set:html={JSON.stringify(offerSchema)}></script>
  <Breadcrumbs items={[
    { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
    { name: 'Coupons', href: '/coupons' },
    { name: c.headline, href: path }
  ]} />
  <Hero eyebrow="Current Offer" title={c.headline} description={c.description} />
  <section class="bg-white py-16 md:py-20 border-b border-mist/60">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="rounded-2xl border-2 border-dashed border-accent-500 bg-paper p-10">
        <p class="label text-accent-600">Coupon</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-charcoal-900">{c.headline}</h2>
        <p class="mt-4 text-charcoal-700 text-lg">{c.offer}</p>
        {c.expires && <p class="mt-3 text-sm text-charcoal-600">Valid through {new Date(c.expires).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
      </div>
      <p class="mt-6 text-sm text-charcoal-600">{c.finePrint}</p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
        <a href={BUSINESS.scheduleUrl} class="rounded-md bg-accent-500 px-6 py-3 font-bold text-charcoal-950 hover:bg-accent-400 transition-colors">Schedule and Redeem</a>
        <a href={BUSINESS.phoneHref} class="rounded-md border-2 border-charcoal-900 px-6 py-3 font-bold text-charcoal-900 hover:bg-charcoal-900 hover:text-paper transition-colors">Call {BUSINESS.phone}</a>
      </div>
    </div>
  </section>
  <RelatedLinks />
  <CTASection title="See Every Current Offer" description={`Browse all specials or call ${BUSINESS.phone} to confirm what's available now.`} />
</BaseLayout>
