---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import { BUSINESS } from '../config';

const path = '/reviews';
const title = 'Reviews | Southlake Auto Care | Jonesboro & Morrow, GA Auto Repair';
const description =
  'See what drivers say about Southlake Auto Care in Morrow, GA — honest service, fair pricing, and quality repairs. Rated 4.8 stars by Clayton County customers.';

{/*
  Reviews are lightly trimmed excerpts of genuine Google Business Profile reviews
  (4.8-star average). Reviewer names were not available in the source data, so
  they are attributed as "Verified Google review" rather than invented.
  Review/AggregateRating schema is intentionally NOT emitted: these reviews
  originate on a third-party platform (Google), and self-serving markup of
  third-party reviews violates Google's structured-data guidelines.
*/}
const reviews = [
  "The staff here is amazing! They truly care about you and your ride. Everyone is very knowledgeable about what's going on and they make sure you feel taken care of. Highly recommend.",
  "As someone who doesn't know a ton about cars, I really appreciated how transparent and patient they were. They made me feel taken care of instead of pressured. Highly recommend this shop for trustworthy service.",
  "I had my vehicle towed in and they had it through emissions and ready by Tuesday. I'm in law enforcement and I definitely trust this shop — you will be satisfied with the quality of the work.",
  "Professional and honest. My vehicle wouldn't pass inspection; they diagnosed it the same day and it passed emissions. I would not hesitate to refer this shop to anyone.",
  "I had a minor issue I thought was major. They quickly fixed it, took the time to explain, and gave recommendations to preserve my car. I appreciate their diligence and professionalism!",
  "Caring and honest company. They got me safely back on the road and took the time to walk me through next steps for my car. Thank you!"
];

// Google Maps place link (external third-party).
const googleReviewsUrl = 'https://www.google.com/maps/place/?q=place_id:ChIJ0WEdMVv59IgRs3XR8wTK5Js';
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <Breadcrumbs
    items={[
      { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
      { name: 'Reviews', href: path }
    ]}
  />

  <section class="bg-charcoal-900 text-paper py-14 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-400">Reviews</p>
      <h1 class="mt-2 text-4xl md:text-5xl font-extrabold tracking-tight">What Clayton County Drivers Say</h1>
      <div class="mt-5 h-1.5 w-24 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <div class="mt-6 flex items-center gap-3">
        <div class="flex gap-1 text-accent-500" aria-label="4.8 out of 5 stars">
          {[0, 1, 2, 3, 4].map(() => (
            <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.4 4.3a1 1 0 00.95.7h4.52c.97 0 1.37 1.24.59 1.81l-3.66 2.66a1 1 0 00-.36 1.12l1.4 4.3c.3.92-.76 1.69-1.54 1.12l-3.66-2.66a1 1 0 00-1.18 0l-3.66 2.66c-.78.57-1.84-.2-1.54-1.12l1.4-4.3a1 1 0 00-.36-1.12L1.6 9.74c-.78-.57-.38-1.8.59-1.8h4.52a1 1 0 00.95-.7l1.4-4.31z"/></svg>
          ))}
        </div>
        <p class="text-lg text-mist"><span class="font-bold text-paper">4.8</span> average on Google</p>
      </div>
    </div>
  </section>

  <!--
    LIVE GOOGLE REVIEWS WIDGET
    A live, rating-filtered Google reviews feed needs a third-party widget
    service (they handle Google's API + display terms and offer a minimum-star
    filter). Recommended free option: Featurable (featurable.com) — create a
    widget for this Business Profile, set the minimum rating to 4 stars, then
    paste its <div> + <script> embed inside the container below. Elfsight and
    Trustindex work the same way. Individual Google reviews are whole-star, so
    "4.5-5 only" = showing 4- and 5-star reviews; the 4.8 average shows as the
    headline. The curated reviews below stay as a fallback until it's connected.
  -->
  <section class="bg-white py-14 md:py-16 border-b border-mist/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">Live Google Reviews</h2>
      <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <div id="google-reviews-widget" class="mt-8">
        {/* Paste the review-widget embed (Featurable / Elfsight / Trustindex) here. */}
      </div>
    </div>
  </section>

  <section class="bg-paper py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map((quote) => (
          <figure class="rounded-xl border border-mist/70 bg-white p-7 flex flex-col">
            <div class="flex gap-1 text-accent-500" aria-label="5 out of 5 stars">
              {[0, 1, 2, 3, 4].map(() => (
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.4 4.3a1 1 0 00.95.7h4.52c.97 0 1.37 1.24.59 1.81l-3.66 2.66a1 1 0 00-.36 1.12l1.4 4.3c.3.92-.76 1.69-1.54 1.12l-3.66-2.66a1 1 0 00-1.18 0l-3.66 2.66c-.78.57-1.84-.2-1.54-1.12l1.4-4.3a1 1 0 00-.36-1.12L1.6 9.74c-.78-.57-.38-1.8.59-1.8h4.52a1 1 0 00.95-.7l1.4-4.31z"/></svg>
              ))}
            </div>
            <blockquote class="mt-4 text-charcoal-700 leading-relaxed flex-1"><p>&ldquo;{quote}&rdquo;</p></blockquote>
            <figcaption class="mt-5 text-sm">
              <span class="font-bold text-charcoal-900">Verified Google review</span>
              <span class="block text-charcoal-500">Southlake AutoCare &middot; 4.8&#9733;</span>
            </figcaption>
          </figure>
        ))}
      </div>
      <p class="mt-8 text-charcoal-600">
        {/* External third-party site — opens in a new tab intentionally */}
        Read more or leave your own on
        <a href={googleReviewsUrl} target="_blank" rel="noopener noreferrer" class="font-semibold text-accent-700 hover:text-accent-600 underline underline-offset-2">Google</a>.
      </p>
    </div>
  </section>

  <CTASection
    title="Experience It Yourself"
    description="Join the drivers who trust Southlake Auto Care. Schedule your visit or call today."
  />
</BaseLayout>
