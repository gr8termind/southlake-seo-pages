---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
import FAQSection from '../components/FAQSection.astro';
import ReviewSection from '../components/ReviewSection.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ServiceSchema from '../components/ServiceSchema.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { BUSINESS } from '../config';
import type { FAQ } from '../config';

const path = '/auto-ac-repair-jonesboro-ga';
const title = 'Auto AC Repair in Jonesboro, GA | AC Recharge, Leaks & More | Southlake Auto Care';
const description =
  'Auto AC repair in Jonesboro, GA. Southlake Auto Care fixes leaks, weak airflow, and warm-air problems — beat the Georgia heat. Call (770) 961-8500.';

const faqs: FAQ[] = [
  {
    q: 'How much does auto AC repair cost in Jonesboro, GA?',
    a: 'It depends on why the AC isn\u2019t cooling. A recharge for a small refrigerant loss is the least expensive; a leak repair adds parts and labor; major component replacement (compressor, evaporator, condenser) costs more. We diagnose first and give you a written estimate before any work &mdash; no obligation.'
  },
  {
    q: 'Why is my AC blowing warm air?',
    a: 'The most common causes are low refrigerant from a leak, a failed compressor clutch, a bad expansion valve or blend door, a blown fuse, or an electrical control problem. Just adding refrigerant without finding the leak is a short-term fix that costs you more in the long run.'
  },
  {
    q: 'Should I just get a recharge from a can at the parts store?',
    a: 'We don\u2019t recommend it, especially for anything more than a very minor loss. Those cans typically contain refrigerant plus a sealer &mdash; and sealers can clog the AC system, damage the compressor, and contaminate our recovery equipment. If your AC needs refrigerant, it almost certainly has a leak, and finding that leak is the actual repair.'
  },
  {
    q: 'How do you find AC leaks?',
    a: 'We use a combination of UV dye, an electronic refrigerant leak detector, and pressure testing to locate leaks. Common failure points are the condenser (often stone-damaged from highway driving), evaporator, compressor front seal, and o-rings at line connections. Sometimes the leak is at multiple points, and we walk through it with you before recommending repairs.'
  },
  {
    q: 'How long does an AC repair take?',
    a: 'A recharge and dye service takes about an hour. Leak repairs and component replacement can take a few hours to a full day depending on where the failed part sits &mdash; an evaporator is buried behind the dash and takes considerably longer than a condenser at the front of the car.'
  },
  {
    q: 'Does the AC affect my fuel economy?',
    a: 'Yes &mdash; and this is why weak AC often shows up as reduced MPG. The compressor puts real load on the engine when it cycles. A system that has a bad clutch, low refrigerant, or a bad pressure sensor can cause the compressor to run improperly, which hurts fuel economy and can even trigger a check engine code.'
  },
  {
    q: 'Do you service both R-134a and R-1234yf systems?',
    a: 'Yes. Vehicles from roughly 2015 onward have moved to R-1234yf, which requires different equipment and is more expensive than the older R-134a. We service both, and we&rsquo;ll match your vehicle&rsquo;s specification before we start.'
  },
  {
    q: 'When is the best time to have my AC checked?',
    a: 'Spring &mdash; before the first stretch of 90&deg;F days &mdash; is ideal. A pre-summer AC check catches slow leaks and weak performance before you actually need the cold air, which is a much better time to schedule the repair.'
  }
];
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <ServiceSchema
    name="Auto AC Repair"
    description="Automotive AC repair, recharge, leak detection, and compressor service in Jonesboro, GA. Both R-134a and R-1234yf systems."
    path={path}
    serviceType="Auto AC Repair"
  />
  <Breadcrumbs
    items={[
      { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
      { name: 'Auto AC Repair', href: path }
    ]}
  />

  <Hero
    eyebrow="AC Service &middot; Jonesboro, GA"
    title="Auto AC Repair in Jonesboro, GA"
    description="Warm air in a Georgia summer isn't a small problem. We diagnose leaks, replace failed components, and get you cold again — usually the same day."
    primaryLabel="Book AC Service"
  />

  <section class="bg-white py-16 md:py-20 border-b border-mist/60">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">A Working AC Is Not a Luxury Here</h2>
      <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <p class="mt-6 text-lg text-charcoal-700 leading-relaxed">
        Around Jonesboro, Morrow, and Clayton County, air conditioning stops being a comfort feature
        somewhere in May and becomes essential equipment through October. Between summer heat, humidity,
        and the reality of sitting in Tara Boulevard traffic with the sun beating on the roof, an AC
        problem goes from &ldquo;annoying&rdquo; to &ldquo;can&rsquo;t drive it&rdquo; in a hurry.
      </p>
      <p class="mt-4 text-lg text-charcoal-700 leading-relaxed">
        Southlake Auto Care fixes AC problems the right way &mdash; find the leak, replace the failed part,
        recharge to spec &mdash; not just top off refrigerant until it runs out again. Drivers throughout
        <a href="/jonesboro-auto-repair" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> Jonesboro</a>,
        <a href="/morrow-auto-repair" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> Morrow</a>,
        <a href="/forest-park-auto-repair" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> Forest Park</a>,
        <a href="/riverdale-auto-repair" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> Riverdale</a>,
        and across
        <a href="/clayton-county-auto-repair" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> Clayton County</a>
        trust our shop for AC work because we fix the underlying cause, not the symptom.
      </p>

      <h2 class="mt-12 text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">Common AC Symptoms We See</h2>
      <ul class="mt-5 space-y-3 text-lg text-charcoal-700">
        <li><strong class="text-charcoal-900">Weak or warm airflow.</strong> AC blows air, but it&rsquo;s not cold. Usually a refrigerant charge issue or a failed component.</li>
        <li><strong class="text-charcoal-900">Cold at highway speed, warm at idle.</strong> Classic sign of a low refrigerant charge or a condenser airflow problem.</li>
        <li><strong class="text-charcoal-900">Musty or moldy smell.</strong> Bacteria buildup on the evaporator &mdash; common in humid Georgia summers, and worth cleaning.</li>
        <li><strong class="text-charcoal-900">Compressor won&rsquo;t engage.</strong> Clutch, relay, pressure switch, or wiring problem.</li>
        <li><strong class="text-charcoal-900">Loud noise from AC.</strong> Failing compressor bearings or a slipping belt.</li>
        <li><strong class="text-charcoal-900">Water on the passenger floor.</strong> A clogged AC drain letting condensate back up into the cabin.</li>
        <li><strong class="text-charcoal-900">Reduced fan speed or no fan.</strong> Blower motor, resistor, or control-module problem.</li>
        <li><strong class="text-charcoal-900">Fogging up the windshield.</strong> A leaking evaporator or heater core letting moisture into the cabin air.</li>
      </ul>

      <h2 class="mt-12 text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">Why AC Systems Fail</h2>
      <p class="mt-5 text-lg text-charcoal-700 leading-relaxed">
        Automotive AC systems are surprisingly complex &mdash; and they live under the hood in a harsh
        environment. Vibration, heat, rock strikes, and normal aging all contribute to failures. The main
        culprits we see:
      </p>
      <ul class="mt-5 space-y-3 text-lg text-charcoal-700">
        <li><strong class="text-charcoal-900">Refrigerant leaks.</strong> All AC systems lose some refrigerant over years, but a real leak &mdash; from a stone-damaged condenser, cracked hose, or bad o-ring &mdash; is what makes an AC stop cooling.</li>
        <li><strong class="text-charcoal-900">Compressor wear.</strong> The compressor is the heart of the AC. Bearings, clutch, and internal seals all wear over 100,000+ miles, especially if the system was ever run low on refrigerant.</li>
        <li><strong class="text-charcoal-900">Electrical failures.</strong> Relays, pressure switches, blend-door actuators, and blower motor resistors are common single-part failures we can pinpoint with a scan tool.</li>
        <li><strong class="text-charcoal-900">Contamination.</strong> Sealers from parts-store cans, moisture from a system that&rsquo;s been open, or debris from a failed compressor can wreck the whole system.</li>
        <li><strong class="text-charcoal-900">Airflow blockage.</strong> A clogged cabin air filter, blocked condenser fins, or failed cooling fan robs performance without any obvious &ldquo;broken part.&rdquo;</li>
      </ul>

      <h2 class="mt-12 text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">Our AC Repair Process</h2>
      <ol class="mt-6 space-y-4 text-lg text-charcoal-700 list-decimal list-inside">
        <li><strong class="text-charcoal-900">Performance check.</strong> We measure vent temperature, high- and low-side pressures, and compressor operation so we know how far the system is off spec.</li>
        <li><strong class="text-charcoal-900">Visual and electrical inspection.</strong> Compressor clutch operation, belt condition, condenser fins, cooling fans, cabin filter, and blend-door actuators.</li>
        <li><strong class="text-charcoal-900">Leak detection.</strong> UV dye and electronic leak detector for refrigerant loss; pressure testing where needed.</li>
        <li><strong class="text-charcoal-900">Written diagnosis and estimate.</strong> Clear explanation of what we found, what needs to happen, and what it&rsquo;ll cost.</li>
        <li><strong class="text-charcoal-900">Repair.</strong> Component replacement, o-rings, hoses, or full system service &mdash; whatever the diagnosis calls for.</li>
        <li><strong class="text-charcoal-900">Evacuate and recharge.</strong> Deep vacuum to pull moisture, then a charge measured by weight to your vehicle&rsquo;s exact spec &mdash; not just &ldquo;until it feels cold.&rdquo;</li>
        <li><strong class="text-charcoal-900">Post-repair performance check.</strong> Verify vent temperature and system pressures under real operating conditions before you drive off.</li>
      </ol>

      <h2 class="mt-12 text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">AC Services We Perform</h2>
      <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          'AC performance check and diagnosis',
          'Refrigerant recharge (R-134a and R-1234yf)',
          'Leak detection with UV dye and electronic tools',
          'Compressor replacement',
          'Condenser and evaporator replacement',
          'Expansion valve and orifice tube service',
          'AC hose, o-ring, and line repair',
          'Blower motor and resistor replacement',
          'Cabin air filter replacement',
          'Cooling fan and radiator service',
          'Heater core and blend-door repair',
          'AC odor removal and evaporator cleaning'
        ].map((item) => (
          <li class="flex items-start gap-3 rounded-lg border border-mist/70 bg-paper px-4 py-3.5 font-semibold text-charcoal-900">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-accent-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-8 8a1 1 0 01-1.4 0l-4-4a1 1 0 111.4-1.4L8 12.6l7.3-7.3a1 1 0 011.4 0z" clip-rule="evenodd"/></svg>
            {item}
          </li>
        ))}
      </ul>

      <h2 class="mt-12 text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">Why Prompt AC Repair Matters</h2>
      <p class="mt-5 text-lg text-charcoal-700 leading-relaxed">
        Running an AC system low on refrigerant is one of the fastest ways to destroy the compressor.
        Refrigerant carries oil that lubricates internal parts &mdash; when the charge drops, the
        compressor runs dry, wears its internals, and often dumps metal debris into the system. What
        started as a $200 leak repair can become a full-system replacement that&rsquo;s several times more
        expensive.
      </p>
      <p class="mt-4 text-lg text-charcoal-700 leading-relaxed">
        There&rsquo;s also the practical Georgia reality: a warm car in July isn&rsquo;t just uncomfortable, it&rsquo;s a
        health issue for kids, older adults, and pets. Fixing it early &mdash; before you actually need the
        cold air &mdash; means you&rsquo;re not scheduling around a heat wave.
      </p>

      <h2 class="mt-12 text-2xl md:text-3xl font-extrabold tracking-tight text-charcoal-900">Related Services</h2>
      <p class="mt-5 text-lg text-charcoal-700 leading-relaxed">
        AC problems sometimes trigger an
        <a href="/check-engine-light-jonesboro-ga" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> check engine or dash warning light</a>,
        especially when compressor engagement or pressures are out of spec. If you&rsquo;re also seeing
        temperature issues under the hood, the cooling system and AC condenser share airflow &mdash; our
        team checks both together. And if AC service arrives at the same time as your next
        <a href="/oil-change-jonesboro-ga" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> oil change</a>,
        we can handle both in one visit. Bigger repair than expected? Ask about our
        <a href="/financing" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2"> financing options</a>
        so you don&rsquo;t have to choose between comfort and your budget.
      </p>
    </div>
  </section>

  <ReviewSection title="What AC Customers in Jonesboro Say" />
  <FAQSection title="Auto AC Repair FAQs" faqs={faqs} />
  <RelatedLinks excludeService="auto-ac-repair-jonesboro-ga" />
  <CTASection
    title="Cold Air Not Coming Back?"
    description={`Call ${BUSINESS.phone} or schedule an AC diagnostic. We\u2019ll find the leak and get you cold — usually the same day.`}
  />
</BaseLayout>
