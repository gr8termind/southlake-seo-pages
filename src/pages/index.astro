---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import CTASection from '../components/CTASection.astro';
import FAQSection from '../components/FAQSection.astro';
import ReviewSection from '../components/ReviewSection.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { BUSINESS } from '../config';
import type { FAQ } from '../config';

const title = 'Auto Repair in Jonesboro, GA | Southlake Auto Care | (770) 961-8500';
const description =
  'Southlake Auto Care provides expert auto repair in Jonesboro, GA — brakes, oil changes, engine diagnostics, AC, and transmission service for Morrow, Forest Park & Clayton County drivers.';

const cards = [
  {
    title: 'Brake Repair',
    description: 'Pads, rotors, calipers, and brake fluid service to restore safe, confident stopping power.',
    href: '/brake-repair-jonesboro-ga',
    icon: 'brake'
  },
  {
    title: 'Oil Change Service',
    description: 'Conventional, blend, and full synthetic oil changes with a multi-point inspection every visit.',
    href: '/oil-change-jonesboro-ga',
    icon: 'oil'
  },
  {
    title: 'Check Engine Light',
    description: 'Professional computer diagnostics that find the real cause behind the warning light — not just the code.',
    href: '/check-engine-light-jonesboro-ga',
    icon: 'engine'
  },
  {
    title: 'Auto AC Repair',
    description: 'Leak detection, compressor repair, and recharge service to keep you cool through Georgia summers.',
    href: '/auto-ac-repair-jonesboro-ga',
    icon: 'ac'
  },
  {
    title: 'Transmission Repair',
    description: 'Fluid service, diagnostics, and repairs for slipping, hard shifting, and transmission warning lights.',
    href: '/transmission-repair-jonesboro-ga',
    icon: 'transmission'
  },
  {
    title: 'Preventative Maintenance',
    description: 'Factory-scheduled maintenance, tune-ups, and inspections that stop small issues from becoming big bills.',
    href: BUSINESS.mainSiteUrl + '/services',
    icon: 'wrench'
  }
] as const;

const faqs: FAQ[] = [
  {
    q: 'Where is Southlake Auto Care located?',
    a: `Our shop is at ${BUSINESS.address.street}, ${BUSINESS.address.city}, GA ${BUSINESS.address.zip} — right in the Southlake area, minutes from Jonesboro, Morrow, and Forest Park. Call ${BUSINESS.phone} for directions or to schedule.`
  },
  {
    q: 'Do you work on all makes and models?',
    a: 'Yes. Our technicians service domestic, Asian, and European vehicles — cars, trucks, SUVs, and vans. Whether you drive a Toyota, Ford, Honda, Chevy, Nissan, or BMW, we can handle your repair and maintenance needs.'
  },
  {
    q: 'Do I need an appointment for auto repair?',
    a: 'Appointments help us get you in and out faster, and you can schedule online in under a minute. We also do our best to accommodate walk-ins and same-day repairs when the schedule allows, especially for urgent brake or safety concerns.'
  },
  {
    q: 'Do you offer financing for larger repairs?',
    a: 'Yes, financing options are available for qualifying repairs, so an unexpected transmission or engine repair does not have to wait. Ask our service advisor about current financing programs when you schedule.'
  },
  {
    q: 'What areas do you serve?',
    a: 'We serve drivers throughout Clayton County, including Jonesboro, Morrow, Forest Park, Lake City, and Rex, plus nearby communities on Atlanta\u2019s southside.'
  }
];
---
<BaseLayout title={title} description={description} canonicalPath="/">
  <Breadcrumbs items={[{ name: 'Home', href: '/' }]} />

  <Hero
    eyebrow="Trusted in Clayton County, GA"
    title="Auto Repair in Jonesboro, GA Done Right the First Time"
    description="From brake repair and oil changes to check engine diagnostics, AC, and transmission service — Southlake Auto Care keeps Jonesboro, Morrow, and Forest Park drivers safely on the road with honest work at fair prices."
  />

  <ServiceCards
    eyebrow="Full-Service Auto Repair"
    title="Our Most-Requested Services in Jonesboro"
    intro="Every repair starts with a clear diagnosis and an upfront estimate. Explore our core services below, or call the shop and tell us what your vehicle is doing — we'll point you in the right direction."
    cards={cards}
  />

  <!-- Why choose us -->
  <section class="bg-paper py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-accent-600">Why Southlake Auto Care</p>
        <h2 class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">
          A Local Shop That Treats Your Car Like Our Own
        </h2>
        <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
        <p class="mt-5 text-lg text-charcoal-700 leading-relaxed">
          Big-chain shops quote from a script. Dealerships charge dealership prices. Southlake Auto Care
          gives Clayton County drivers a third option: experienced technicians, honest recommendations,
          and repairs backed by quality parts — all from a shop on Jonesboro Road that knows its neighbors.
        </p>
        <p class="mt-4 text-lg text-charcoal-700 leading-relaxed">
          We explain what your vehicle needs now, what can safely wait, and why — so every dollar you
          spend is a decision you understand.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href={BUSINESS.ctaUrl} class="rounded-md bg-charcoal-900 px-7 py-3.5 text-center font-bold text-paper hover:bg-charcoal-800 transition-colors">Schedule Service</a>
          <a href={BUSINESS.phoneHref} class="rounded-md border-2 border-charcoal-900 px-7 py-3.5 text-center font-bold text-charcoal-900 hover:bg-charcoal-900 hover:text-paper transition-colors">Call {BUSINESS.phone}</a>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {[
          { h: 'Honest Diagnostics', p: 'We show you the problem before we fix it — worn parts, readings, and all.' },
          { h: 'Upfront Estimates', p: 'Clear pricing before work begins. No surprise line items at pickup.' },
          { h: 'Quality Parts', p: 'Name-brand and OE-quality parts installed by experienced technicians.' },
          { h: 'Convenient Location', p: 'On Jonesboro Road in the Southlake area — easy from I-75 and Highway 54.' }
        ].map((item) => (
          <div class="rounded-xl border border-mist/70 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-bold text-charcoal-900 flex items-center gap-2.5">
              <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent-500 text-charcoal-950" aria-hidden="true">
                <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-8 8a1 1 0 01-1.4 0l-4-4a1 1 0 111.4-1.4L8 12.6l7.3-7.3a1 1 0 011.4 0z" clip-rule="evenodd"/></svg>
              </span>
              {item.h}
            </h3>
            <p class="mt-2.5 text-charcoal-700 text-[15px] leading-relaxed">{item.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service areas -->
  <section class="bg-white py-16 md:py-20 border-y border-mist/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-600">Areas We Serve</p>
      <h2 class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">
        Serving Jonesboro, Morrow &amp; Forest Park
      </h2>
      <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <p class="mt-5 max-w-3xl text-lg text-charcoal-700 leading-relaxed">
        Our shop sits in the heart of Clayton County, which means most of our customers are less than
        fifteen minutes away. Learn more about how we serve your city:
      </p>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-5">
        <a href="/morrow-auto-repair" class="rounded-xl border border-mist/70 bg-paper p-6 hover:border-accent-500/60 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold text-charcoal-900">Morrow Auto Repair</h3>
          <p class="mt-2 text-charcoal-700 text-[15px]">Minutes from Southlake Mall and Clayton State — full-service repair for Morrow drivers.</p>
        </a>
        <a href="/forest-park-auto-repair" class="rounded-xl border border-mist/70 bg-paper p-6 hover:border-accent-500/60 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold text-charcoal-900">Forest Park Auto Repair</h3>
          <p class="mt-2 text-charcoal-700 text-[15px]">A quick drive down Highway 41 or I-75 — trusted repair for Forest Park families and fleets.</p>
        </a>
        <div class="rounded-xl border border-mist/70 bg-paper p-6">
          <h3 class="text-xl font-bold text-charcoal-900">Clayton County &amp; Beyond</h3>
          <p class="mt-2 text-charcoal-700 text-[15px]">Lake City, Rex, Riverdale, Stockbridge, and Atlanta southside drivers are always welcome.</p>
        </div>
      </div>
    </div>
  </section>

  <ReviewSection />
  <FAQSection title="Auto Repair Questions, Answered" faqs={faqs} />
  <CTASection />
</BaseLayout>
