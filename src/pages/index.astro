---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import ReviewSection from '../components/ReviewSection.astro';
import QuoteForm from '../components/QuoteForm.astro';
import CTASection from '../components/CTASection.astro';
import type { ServiceCard } from '../components/ServiceCards.astro';
import { BUSINESS } from '../config';

const path = '/';
const title = 'SouthLake AutoCare | Auto Repair Shop in Jonesboro & Morrow, GA';
const description =
  'Southlake Auto Care is a trusted auto repair shop in Jonesboro, GA specializing in brake repair, oil changes, engine diagnostics, AC repair, transmission service, and preventative maintenance for drivers throughout Clayton County.';

const services: ServiceCard[] = [
  { title: 'Brake Repair', description: 'Pads, rotors, calipers, and brake diagnostics — stop safely with a free brake inspection.', href: '/brake-repair-jonesboro-ga', icon: 'brake' },
  { title: 'Oil Changes', description: 'Full synthetic, blend, or conventional — with a multi-point inspection every time.', href: '/oil-change-jonesboro-ga', icon: 'oil' },
  { title: 'Check Engine Light', description: 'Accurate computer diagnostics to find the real cause — not just clear the code.', href: '/check-engine-light-jonesboro-ga', icon: 'engine' },
  { title: 'AC Repair', description: 'Beat the Georgia heat. Leak detection, recharge, and full AC system service.', href: '/auto-ac-repair-jonesboro-ga', icon: 'ac' },
  { title: 'Transmission Service', description: 'From fluid service to full repair — honest options for slipping and hard shifts.', href: '/transmission-repair-jonesboro-ga', icon: 'transmission' },
  { title: 'Maintenance & More', description: 'Factory-schedule maintenance, tune-ups, and the everyday repairs that keep you rolling.', href: '/schedule-service', icon: 'wrench' }
];

const reasons = [
  { h: 'Honest Diagnostics', p: 'We find the real problem and tell you the truth — even when the answer is "it can wait."' },
  { h: 'Upfront Pricing', p: 'You approve the work before we start. No surprise charges when you pick up your car.' },
  { h: 'Quality Workmanship', p: 'The right parts, installed by technicians who stand behind the repair.' },
  { h: 'Fast Turnaround', p: 'Most maintenance is same-day, and we respect your time from drop-off to pickup.' }
];
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <Hero
    eyebrow="Jonesboro · Morrow · Forest Park, GA"
    title="Trusted Auto Repair in Jonesboro & Clayton County"
    description="From brakes and oil changes to check-engine diagnostics, AC, and transmissions — Southlake Auto Care fixes your vehicle right the first time, with honest advice and pricing you can trust."
    primaryLabel="Request a Quote"
  />

  <!-- Trust strip -->
  <section class="bg-charcoal-950 text-paper">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { n: '4.8★', l: 'Google Rating' },
        { n: 'Same-Day', l: 'Most Services' },
        { n: 'Honest', l: 'Upfront Pricing' },
        { n: 'Clayton Co.', l: 'Locally Trusted' }
      ].map((s) => (
        <div>
          <p class="text-2xl font-extrabold text-accent-500">{s.n}</p>
          <p class="mt-1 text-sm text-smoke">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  <ServiceCards
    eyebrow="What We Do"
    title="Full-Service Auto Repair Under One Roof"
    intro="Whatever your vehicle needs, our technicians handle it — cars, trucks, and SUVs, domestic and import."
    cards={services}
  />

  <!-- Why choose us -->
  <section class="bg-paper py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-widest text-accent-600">Why Southlake Auto Care</p>
        <h2 class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">Repairs You Can Actually Trust</h2>
        <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
        <p class="mt-5 text-lg text-charcoal-700 leading-relaxed">
          Drivers across Jonesboro, Morrow, and Forest Park keep coming back for one reason: we treat
          your car — and your wallet — the way we'd want ours treated.
        </p>
      </div>
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {reasons.map((r) => (
          <div class="rounded-xl border border-mist/70 bg-white p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent-500 text-charcoal-950">
              <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-8 8a1 1 0 01-1.4 0l-4-4a1 1 0 111.4-1.4L8 12.6l7.3-7.3a1 1 0 011.4 0z" clip-rule="evenodd"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-charcoal-900">{r.h}</h3>
            <p class="mt-2 text-charcoal-700 text-[15px] leading-relaxed">{r.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas served -->
  <section class="bg-white py-16 md:py-20 border-y border-mist/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-widest text-accent-600">Areas We Serve</p>
        <h2 class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight text-charcoal-900">Proudly Serving Clayton County</h2>
        <div class="mt-4 h-1.5 w-16 bg-accent-500 rounded-full" aria-hidden="true"></div>
        <p class="mt-5 text-lg text-charcoal-700 leading-relaxed">
          Conveniently located at {BUSINESS.address.street} in {BUSINESS.address.city} — minutes from
          Jonesboro, Morrow, Forest Park, Lake City, and Rex.
        </p>
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/morrow-auto-repair" class="rounded-lg border border-mist/70 bg-paper px-6 py-4 font-bold text-charcoal-900 hover:border-accent-500 hover:text-accent-700 transition-colors">Auto Repair in Morrow &rarr;</a>
        <a href="/forest-park-auto-repair" class="rounded-lg border border-mist/70 bg-paper px-6 py-4 font-bold text-charcoal-900 hover:border-accent-500 hover:text-accent-700 transition-colors">Auto Repair in Forest Park &rarr;</a>
        <a href="/brake-repair-jonesboro-ga" class="rounded-lg border border-mist/70 bg-paper px-6 py-4 font-bold text-charcoal-900 hover:border-accent-500 hover:text-accent-700 transition-colors">Auto Repair in Jonesboro &rarr;</a>
      </div>
    </div>
  </section>

  <ReviewSection title="What Our Customers Say" />

  <QuoteForm
    title="Get a Free Quote"
    intro="Tell us about your vehicle and what it needs. We'll get you a quote and get you on the schedule."
  />

  <CTASection
    title="Ready to Get Back on the Road?"
    description="Schedule online or call our Jonesboro-area shop today. We'll diagnose the problem, explain your options, and fix it right the first time."
  />
</BaseLayout>
