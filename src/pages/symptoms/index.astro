---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { BUSINESS } from '../../config';
import { SYMPTOMS } from '../../data/symptoms';

const path = '/symptoms';
const title = 'Vehicle Symptoms Guide | Southlake Auto Care | Jonesboro & Morrow, GA';
const description = "Not sure what's wrong with your car? Look up common vehicle symptoms and learn what they usually mean. Southlake Auto Care in Morrow, GA — (770) 961-8500.";
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <Breadcrumbs items={[
    { name: 'Home', href: BUSINESS.mainSiteUrl + '/' },
    { name: 'Vehicle Symptoms', href: path }
  ]} />
  <Hero eyebrow="Symptom Library" title="What's Wrong With My Car?" description="Look up what you're experiencing and we'll tell you what usually causes it — and how we'd fix it." />
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {SYMPTOMS.length === 0 ? (
        <p class="text-lg text-charcoal-700 leading-relaxed">
          Our symptom guides are being added. In the meantime, try our interactive
          <a href="/car-diagnostic" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2">car diagnostic tool</a>
          or call <a href={BUSINESS.phoneHref} class="font-bold text-accent-700 hover:text-accent-600">{BUSINESS.phone}</a> to describe what's happening.
        </p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {SYMPTOMS.map((s) => (
            <a href={`/symptoms/${s.slug}`} class="rounded-xl border border-mist/70 bg-paper p-6 hover:border-accent-500 hover:shadow-sm transition-all">
              <h2 class="text-xl font-bold text-charcoal-900">{s.symptom}</h2>
              <p class="mt-2 text-sm text-charcoal-700 leading-relaxed">{s.description.split('.')[0]}.</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  <RelatedLinks />
  <CTASection title="Need a Real Diagnosis?" description={`Book a diagnostic — we'll pin down the cause instead of guessing.`} />
</BaseLayout>
