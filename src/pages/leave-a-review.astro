---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BUSINESS } from '../config';

const path = '/leave-a-review';
const title = 'Leave a Review | Southlake Auto Care | Jonesboro & Morrow, GA';
const description =
  'How was your visit to Southlake Auto Care? Rate your experience — share it on Google or send feedback directly to our team.';

// Direct "write a review" link for the Google Business Profile.
const googleReviewUrl = 'https://search.google.com/local/writereview?placeid=ChIJ0WEdMVv59IgRs3XR8wTK5Js';
---
<BaseLayout title={title} description={description} canonicalPath={path}>
  <section class="bg-charcoal-900 text-paper py-16 md:py-24">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-400">Your Feedback</p>
      <h1 class="mt-2 text-4xl md:text-5xl font-extrabold tracking-tight">How Was Your Visit?</h1>
      <div class="mx-auto mt-5 h-1.5 w-24 bg-accent-500 rounded-full" aria-hidden="true"></div>
      <p class="mt-6 text-lg text-mist">Tap a star to rate your experience at {BUSINESS.name}.</p>

      <!-- Star rating -->
      <div id="stars" class="mt-8 flex items-center justify-center gap-2" role="radiogroup" aria-label="Rate your experience from 1 to 5 stars">
        {[1, 2, 3, 4, 5].map((n) => (
          <button
            type="button"
            class="star-btn text-charcoal-600 hover:text-accent-400 transition-colors"
            data-value={n}
            role="radio"
            aria-checked="false"
            aria-label={`${n} star${n > 1 ? 's' : ''}`}
          >
            <svg class="h-10 w-10 md:h-12 md:w-12" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.4 4.3a1 1 0 00.95.7h4.52c.97 0 1.37 1.24.59 1.81l-3.66 2.66a1 1 0 00-.36 1.12l1.4 4.3c.3.92-.76 1.69-1.54 1.12l-3.66-2.66a1 1 0 00-1.18 0l-3.66 2.66c-.78.57-1.84-.2-1.54-1.12l1.4-4.3a1 1 0 00-.36-1.12L1.6 9.74c-.78-.57-.38-1.8.59-1.8h4.52a1 1 0 00.95-.7l1.4-4.31z"/></svg>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Positive path: shown for 4-5 stars -->
  <section id="panel-positive" class="hidden bg-white py-16 md:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-charcoal-900">Thank You! 🎉</h2>
      <p class="mt-4 text-lg text-charcoal-700">
        We're so glad you had a great experience. Would you take a moment to share it on Google?
        It genuinely helps other local drivers find us.
      </p>
      <a href={googleReviewUrl} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-8 py-4 text-base font-bold text-charcoal-950 hover:bg-accent-400 transition-colors">
        Leave a Google Review
      </a>
      <p class="mt-6 text-sm text-charcoal-600">
        Something we could do better? <button type="button" data-show="feedback" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2">Send us private feedback</button> instead.
      </p>
    </div>
  </section>

  <!-- Feedback path: shown for 1-3 stars -->
  <section id="panel-feedback" class="hidden bg-white py-16 md:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-charcoal-900">We Want to Make It Right</h2>
        <p class="mt-4 text-lg text-charcoal-700">
          We're sorry your visit fell short. Tell us what happened and it goes straight to our
          management team — we read every message and will reach out to make it right.
        </p>
        <a href={BUSINESS.phoneHref} class="mt-6 inline-flex items-center justify-center gap-2 rounded-md border-2 border-charcoal-900 px-6 py-3 text-sm font-bold text-charcoal-900 hover:bg-charcoal-900 hover:text-paper transition-colors">
          Or call us now: {BUSINESS.phone}
        </a>
      </div>

      {/*
        TODO: Wire this form to send to management before launch — a Cloudflare
        Pages Function, Formspree endpoint, or your Base44 backend / email.
        Until wired, the phone button above is the live path.
      */}
      <form action="#" method="post" class="mt-8 space-y-4">
        <input type="hidden" name="rating" id="feedback-rating" value="" />
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="fname" class="block text-sm font-semibold text-charcoal-900">Name</label>
            <input id="fname" name="name" type="text" autocomplete="name" required class="mt-1.5 w-full rounded-md border border-mist bg-paper px-4 py-3 text-charcoal-900 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/30" />
          </div>
          <div>
            <label for="fphone" class="block text-sm font-semibold text-charcoal-900">Phone or Email</label>
            <input id="fphone" name="contact" type="text" autocomplete="tel" required class="mt-1.5 w-full rounded-md border border-mist bg-paper px-4 py-3 text-charcoal-900 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/30" />
          </div>
        </div>
        <div>
          <label for="fmsg" class="block text-sm font-semibold text-charcoal-900">What could we have done better?</label>
          <textarea id="fmsg" name="message" rows="5" required class="mt-1.5 w-full rounded-md border border-mist bg-paper px-4 py-3 text-charcoal-900 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/30"></textarea>
        </div>
        <button type="submit" class="w-full rounded-md bg-accent-500 px-6 py-4 text-base font-bold text-charcoal-950 hover:bg-accent-400 transition-colors">
          Send to Management
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-charcoal-600">
        You're also always welcome to
        <a href={googleReviewUrl} target="_blank" rel="noopener noreferrer" class="font-bold text-accent-700 hover:text-accent-600 underline underline-offset-2">leave a public review on Google</a>.
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const stars = Array.from(document.querySelectorAll('.star-btn'));
      const panelPositive = document.getElementById('panel-positive');
      const panelFeedback = document.getElementById('panel-feedback');
      const ratingField = document.getElementById('feedback-rating');

      function paint(value) {
        stars.forEach((s) => {
          const v = Number(s.getAttribute('data-value'));
          s.classList.toggle('text-accent-500', v <= value);
          s.classList.toggle('text-charcoal-600', v > value);
          s.setAttribute('aria-checked', String(v === value));
        });
      }

      function choose(value) {
        paint(value);
        if (ratingField) ratingField.value = String(value);
        const positive = value >= 4;
        panelPositive.classList.toggle('hidden', !positive);
        panelFeedback.classList.toggle('hidden', positive);
        const target = positive ? panelPositive : panelFeedback;
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      stars.forEach((s) => {
        const v = Number(s.getAttribute('data-value'));
        s.addEventListener('mouseenter', () => paint(v));
        s.addEventListener('focus', () => paint(v));
        s.addEventListener('click', () => choose(v));
      });
      const starWrap = document.getElementById('stars');
      if (starWrap) starWrap.addEventListener('mouseleave', () => {
        const checked = stars.find((s) => s.getAttribute('aria-checked') === 'true');
        paint(checked ? Number(checked.getAttribute('data-value')) : 0);
      });

      document.querySelectorAll('[data-show="feedback"]').forEach((btn) => {
        btn.addEventListener('click', () => {
          panelPositive.classList.add('hidden');
          panelFeedback.classList.remove('hidden');
          panelFeedback.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    })();
  </script>
</BaseLayout>
